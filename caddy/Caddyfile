# Caddyfile - automatic HTTPS reverse proxy for the Hermes stack.

{
	email {$ACME_EMAIL}
}

# Hermes Workspace - public web UI.
{$DASHBOARD_DOMAIN} {
	encode zstd gzip
	reverse_proxy workspace:3000
}

# Optional 9Router admin dashboard.
{$ROUTER_DOMAIN:router.invalid} {
	encode zstd gzip
	reverse_proxy 9router:{$PORT:20128}
}
