# Caddyfile — automatic HTTPS reverse proxy for the Hermes stack.
# Domains and email come from the environment (see docker-compose.yml / .env).
# Caddy provisions and renews Let's Encrypt certificates automatically.

{
	email {$ACME_EMAIL}
}

# Hermes Workspace — the public entry point.
{$HERMES_DOMAIN} {
	encode zstd gzip
	reverse_proxy workspace:3000
}

# OPTIONAL 9Router admin dashboard.
# This block only activates when ROUTER_DOMAIN is set in .env; when empty,
# Caddy serves it on an unreachable placeholder host, keeping 9Router internal.
{$ROUTER_DOMAIN:router.invalid} {
	encode zstd gzip
	reverse_proxy 9router:{$PORT:20128}
}
