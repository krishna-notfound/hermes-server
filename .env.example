# .env.example
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Never commit .env. Generate secrets with:
#   openssl rand -hex 32

# Domains and TLS.
DASHBOARD_DOMAIN=dashboard.example.com
ACME_EMAIL=admin@example.com

# Expose 9Router's admin dashboard on its own hostname.
ROUTER_DOMAIN=router.example.com

# Hermes gateway auth. Workspace uses this for the gateway on :8642.
API_SERVER_KEY=change-me-openssl-rand-hex-32

# Hermes Agent dashboard auth. These are official Hermes dashboard basic-auth
# variables for self-hosted deployments. Use a strong password and a stable
# secret so sessions survive container restarts.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=change-me-strong-dashboard-password
HERMES_DASHBOARD_BASIC_AUTH_SECRET=change-me-openssl-rand-hex-32

# Hermes Workspace login.
HERMES_PASSWORD=change-me-strong-workspace-password

# Host file ownership for ./volumes/hermes. Set to `id -u` / `id -g` on Linux.
HERMES_UID=1000
HERMES_GID=1000

# 9Router.
PORT=20128
JWT_SECRET=change-me-openssl-rand-hex-32
API_KEY_SECRET=change-me-openssl-rand-hex-32
MACHINE_ID_SALT=change-me-openssl-rand-hex-32
INITIAL_PASSWORD=change-me-9router-admin-password

# Created after first boot inside the 9Router dashboard, then pasted here.
ROUTER_API_KEY=
