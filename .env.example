# .env.example
# Copy to .env and fill in real values:  cp .env.example .env
# NEVER commit .env — it is git-ignored. Generate secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains & TLS (Caddy) ───────────────────────────────────────────────────
# The public hostname for Hermes Workspace. Point its DNS A/AAAA record at this host.
HERMES_DOMAIN=hermes.example.com
# Email used for Let's Encrypt registration / expiry notices.
ACME_EMAIL=admin@example.com
# OPTIONAL: expose the 9Router admin dashboard on its own hostname.
# Leave EMPTY to keep 9Router internal-only (recommended). If set, add a DNS record too.
ROUTER_DOMAIN=router.example.com

# ── Shared Hermes gateway auth ──────────────────────────────────────────────
# Protects the Hermes Agent gateway API. The Workspace authenticates with the
# same value (wired automatically in docker-compose.yml). Generate a strong one.
API_SERVER_KEY=change-me-openssl-rand-hex-32

# ── Hermes Workspace UI login ───────────────────────────────────────────────
# Password for the web UI login screen (required — the UI is internet-facing).
HERMES_PASSWORD=change-me-strong-password

# ── Host file ownership for the Hermes data volume ──────────────────────────
# The agent remaps its internal user to these IDs so files in ./volumes/hermes
# stay owned by you on the host. Set to your user:  id -u  /  id -g
HERMES_UID=1000
HERMES_GID=1000

# ── 9Router ─────────────────────────────────────────────────────────────────
# Internal port 9Router listens on (not published to the host).
PORT=20128
# Secrets — generate each with `openssl rand -hex 32`.
JWT_SECRET=change-me-openssl-rand-hex-32
API_KEY_SECRET=change-me-openssl-rand-hex-32
MACHINE_ID_SALT=change-me-openssl-rand-hex-32
# First-login password for the 9Router admin dashboard. Change after first login.
INITIAL_PASSWORD=change-me-9router-admin-password

# ── Hermes → 9Router API key ────────────────────────────────────────────────
# Created AFTER first boot, inside the 9Router dashboard (Settings → API Keys).
# Leave blank on the very first `up`, then paste the key here and restart the
# hermes-agent service. See the README "Connecting Hermes to 9Router" section.
ROUTER_API_KEY=
